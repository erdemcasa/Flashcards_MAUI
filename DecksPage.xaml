<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlashCard.DecksPage"
             Title="Mes decks">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16" RowSpacing="12">

        <Label Text="Gestion des decks"
               FontSize="26"
               FontAttributes="Bold"
               TextColor="#281451" />

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <Entry x:Name="NewDeckEntry"
                   Placeholder="Nom du nouveau deck"
                   ClearButtonVisibility="WhileEditing" />
            <Button Grid.Column="1"
                    Text="Ajouter"
                    Clicked="OnAddDeckClicked"
                    BackgroundColor="#281451"
                    TextColor="White" />
        </Grid>

        <CollectionView Grid.Row="2"
                        x:Name="DecksCollectionView"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,4"
                            Padding="14"
                            Stroke="#DDD7F2"
                            BackgroundColor="White">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="16" />
                        </Border.StrokeShape>

                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8" ColumnSpacing="10">
                            <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="4">
                                <Label Text="{Binding Name}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#281451" />
                                <Label Text="{Binding CardCount, StringFormat='{0} cartes'}"
                                       FontSize="13"
                                       TextColor="#6E6E6E" />
                                <Label Text="{Binding CreatedDate, StringFormat='Créé le {0:dd/MM/yyyy}'}"
                                       FontSize="12"
                                       TextColor="#9A9A9A" />
                            </VerticalStackLayout>

                            <Button Grid.Row="0"
                                    Grid.Column="1"
                                    Text="Cartes"
                                    Clicked="OnOpenDeckClicked"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="#DED9EE"
                                    TextColor="#281451" />

                            <HorizontalStackLayout Grid.Row="1"
                                                   Grid.ColumnSpan="2"
                                                   Spacing="8"
                                                   HorizontalOptions="End">
                                <Button Text="Renommer"
                                        Clicked="OnEditDeckClicked"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#F1EAFE"
                                        TextColor="#281451" />
                                <Button Text="Supprimer"
                                        Clicked="OnDeleteDeckClicked"
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#FCE8E6"
                                        TextColor="#A10D0D" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="8">
                    <Label Text="📚" FontSize="56" HorizontalOptions="Center" />
                    <Label Text="Aucun deck pour le moment"
                           FontSize="18"
                           TextColor="#6E6E6E"
                           HorizontalOptions="Center" />
                    <Label Text="Créez un deck pour commencer à ajouter des cartes"
                           FontSize="13"
                           TextColor="#9A9A9A"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <Label Grid.Row="3"
               x:Name="InfoLabel"
               Text="Prêt"
               FontSize="12"
               TextColor="#6E6E6E"
               HorizontalOptions="Center" />
    </Grid>
</ContentPage>