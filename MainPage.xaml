<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlashCard.MainPage"
             BackgroundColor="#281451">

    <Grid RowDefinitions="80, *">

        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="20, 10">
            <Label Text="FLASH67" 
                   TextColor="White" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   VerticalOptions="Center" 
                   HorizontalOptions="Start"/>

            <Label Grid.Column="1" 
                   Text="erdemcasa" 
                   TextColor="White" 
                   VerticalOptions="Center" 
                   Margin="0,0,10,0"/>
        </Grid>

        <Border Grid.Row="1" 
                BackgroundColor="#DED9EE" 
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="40,40,0,0" />
            </Border.StrokeShape>

            <StackLayout Padding="20, 25">

                <FlexLayout JustifyContent="SpaceAround" Margin="0,0,0,25">
                    <Frame BackgroundColor="White" 
                           CornerRadius="20" 
                           HasShadow="False" 
                           Padding="15, 8" 
                           BorderColor="Transparent">
                        <Label Text="Decks publics" 
                               TextColor="#281451" 
                               FontAttributes="Bold"
                               HorizontalOptions="Center"/>
                    </Frame>

                    <Label Text="Mes decks" 
                           TextColor="#281451" 
                           VerticalOptions="Center" 
                           FontAttributes="Bold"/>

                    <Label Text="Catégories" 
                           TextColor="#281451" 
                           VerticalOptions="Center" 
                           FontAttributes="Bold"/>
                </FlexLayout>

                <Border Stroke="#281451"
                        StrokeThickness="1"
                        BackgroundColor="White"
                        HeightRequest="45"
                        HorizontalOptions="Center"
                        WidthRequest="300">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="22" />
                    </Border.StrokeShape>

                    <Entry Placeholder="Rechercher deck..."
                           PlaceholderColor="#7D7D7D"
                           TextColor="#281451"
                           FontSize="15"
                           HorizontalTextAlignment="Center"
                           BackgroundColor="Transparent"
                           Margin="15,0"/>
                </Border>

                <ScrollView Margin="0,20,0,0">
                    <VerticalStackLayout Spacing="10">
                    </VerticalStackLayout>
                </ScrollView>

            </StackLayout>
        </Border>
    </Grid>
</ContentPage>