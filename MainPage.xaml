<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FlashCard.MainPage"
             BackgroundColor="#281451">

    <Grid RowDefinitions="Auto,*" Padding="20">
        <VerticalStackLayout Spacing="8">
            <Label Text="FlashCard"
                   TextColor="White"
                   FontSize="30"
                   FontAttributes="Bold" />
            <Label x:Name="StatsLabel"
                   Text="Chargement..."
                   TextColor="#DDD9EE"
                   FontSize="14" />
        </VerticalStackLayout>

        <Border Grid.Row="1"
                BackgroundColor="#DED9EE"
                StrokeThickness="0">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="36,36,0,0" />
            </Border.StrokeShape>

            <VerticalStackLayout Padding="20" Spacing="16">
                <Label Text="Votre espace d'apprentissage"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#281451" />

                <Label Text="Gérez vos decks, puis ajoutez, modifiez et supprimez les cartes depuis une interface unique."
                       FontSize="14"
                       TextColor="#4A4A4A" />

                <Button Text="Ouvrir mes decks"
                        Clicked="OnOpenDecksClicked"
                        BackgroundColor="#281451"
                        TextColor="White" />

                <Button Text="Créer un deck"
                        Clicked="OnCreateDeckClicked"
                        BackgroundColor="#F1EAFE"
                        TextColor="#281451" />

                <CollectionView x:Name="RecentDecksCollectionView"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,4"
                                    Padding="14"
                                    Stroke="#DDD7F2"
                                    BackgroundColor="White">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16" />
                                </Border.StrokeShape>

                                <VerticalStackLayout Spacing="4">
                                    <Label Text="{Binding Name}"
                                           FontSize="17"
                                           FontAttributes="Bold"
                                           TextColor="#281451" />
                                    <Label Text="{Binding CardCount, StringFormat='{0} cartes'}"
                                           FontSize="13"
                                           TextColor="#6E6E6E" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>